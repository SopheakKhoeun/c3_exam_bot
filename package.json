{
  "name": "wmad-c3-exam-prep-bot",
  "version": "1.0.0",
  "description": "WMAD C3 Exam Prep Bot — Telegram bot for practical exam practice questions",
  "main": "src/bot.js",
  "scripts": {
    "start": "node src/bot.js",
    "dev": "node --watch src/bot.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "node seed/seed.js",
    "db:studio": "prisma studio",
    "pm2:start": "pm2 start src/bot.js --name wmad-c3-bot",
    "pm2:stop": "pm2 stop wmad-c3-bot",
    "pm2:logs": "pm2 logs wmad-c3-bot",
    "pm2:restart": "pm2 restart wmad-c3-bot"
  },
  "keywords": [
    "telegram",
    "telegraf",
    "exam",
    "wmad",
    "prisma"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "node-cron": "^4.6.0",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "prisma": "^6.9.0"
  },
  "prisma": {
    "seed": "node seed/seed.js"
  }
}
